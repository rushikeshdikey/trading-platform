# Copy to .env (gitignored) and fill values. App reads via app/config.py.

# dev | prod. In prod, SECRET_KEY must be strong and DATABASE_URL must be Postgres.
ENV=dev

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Required in production. Used for signed session cookies (Phase 2 auth).
SECRET_KEY=dev-insecure-change-me-in-production-abcdefghijk

# SQLAlchemy URL.
#   dev:  leave blank to use sqlite:///data/journal.db
#   prod: postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=

# Kite Connect (Zerodha) credentials. Optional; leave blank to disable.
# Phase 2 will move these to per-user encrypted columns; this stays as
# fallback for the bootstrap admin user.
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:8000/auth/zerodha/callback
