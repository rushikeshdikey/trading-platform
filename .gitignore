.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
data/*.db
data/*.db-journal
.DS_Store
.env
.idea/
.vscode/

# Tailwind CLI binary (downloaded by tailwind/build.sh)
bin/
# Note: app/static/app.css is checked in so dev works without running the
# Tailwind build first. CI/Docker build re-runs build.sh to refresh it.

# Terraform state and per-env tfvars (may contain secrets)
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/terraform/terraform.tfvars
infra/terraform/*.auto.tfvars
